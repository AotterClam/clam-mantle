# Local-only vars wrangler dev reads. NOT deployed.
# Copy this file to `.dev.vars` and fill in the GitHub OAuth section
# below before running `pnpm dev` if you need to sign in at /admin.
# Public read routes (the rendered publication) work without any OAuth.

# StubOAuthVerifier flag — accepts `Authorization: Bearer dev-<user_id>`
# headers on /mcp etc., the cheap way to exercise role-gated paths from
# curl/scripts (see `Smoke test` in README.md). Does NOT affect the
# browser admin SPA sign-in flow, which always uses real GitHub OAuth.
# Production: remove.
CLAM_ALLOW_STUB_OAUTH=1

# Cloudflare Turnstile secret key. Default `dev-stub` short-circuits
# siteverify with a literal-string check (turnstileToken === "fail"
# rejects, anything else passes). Production: real secret via
# `wrangler secret put TURNSTILE_SECRET_KEY`.
TURNSTILE_SECRET_KEY=dev-stub

# Live-render mode in local dev — bypass KV cache so chrome edits
# (Header, Layout, styles, i18n) show on every route immediately.
# Don't set in production.
CLAM_LOCAL_DEV=1

# ── Admin SPA sign-in (required for /admin; public routes don't need this) ──
# Even on local dev, /admin uses real GitHub OAuth — there is no stub
# for the browser redirect flow. To use /admin locally:
#
#   1. Create a GitHub OAuth App at github.com/settings/developers
#      - Homepage URL:    http://localhost:8787
#      - Callback URL:    http://localhost:8787/admin/auth/github/callback
#   2. Paste the client id / secret below.
#   3. Set ADMIN_GITHUB_LOGIN to YOUR GitHub login. The runtime's
#      `ensureBootstrapOwner` promotes whoever signs in matching this
#      login to `owner` on first sign-in (only fires while the staff
#      table is empty — `pnpm fixture` deliberately leaves it empty).
#
# The same OAuth App can be reused for production by adding the
# deployed callback URL alongside the localhost one.
GITHUB_CLIENT_ID=<your_github_oauth_app_client_id>
GITHUB_CLIENT_SECRET=<your_github_oauth_app_client_secret>
ADMIN_GITHUB_LOGIN=<your_github_login>
