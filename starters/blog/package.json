{
  "name": "@aotterclam/starter-blog",
  "version": "0.0.0",
  "private": true,
  "description": "Reference starter for clam-cms v0.1.0. Localized posts (translates demo) + contact form (builtin + lifecycle hooks). Runs on wrangler dev with local D1 + KV.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "fixture": "tsx test/fixture/apply.ts",
    "mcp-smoke": "tsx test/integration/mcp-smoke.ts",
    "view-smoke": "tsx test/integration/view-rest-smoke.ts",
    "validate": "clam-cms validate",
    "introspect": "clam-cms introspect",
    "emit-openapi": "clam-cms emit-openapi > openapi.json",
    "emit-types": "clam-cms emit-types --namespace BlogCms > clam-types.d.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "pnpm validate && pnpm typecheck",
    "deploy": "wrangler deploy",
    "setup:site": "node scripts/setup-site.mjs",
    "provision:plan": "node scripts/provision.mjs plan",
    "provision:up": "node scripts/provision.mjs up",
    "seed:initial": "tsx scripts/seed-initial-content.ts",
    "theme:fork": "node scripts/theme-fork.mjs",
    "theme:reset": "node scripts/theme-reset.mjs"
  },
  "dependencies": {
    "@aotterclam/clam-cms-spec": "workspace:*",
    "@aotterclam/clam-cms-runtime": "workspace:*",
    "@aotterclam/clam-cms-cloudflare": "workspace:*",
    "hono": "^4.6.20",
    "marked": "^14.1.3",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.103.2"
  }
}
