# Local-only vars wrangler dev reads. NOT deployed.
# StubOAuthVerifier requires this flag so dev tokens (Bearer dev-<id>)
# are accepted. Production wires the real DCR-compliant verifier — DO
# NOT set CLAM_ALLOW_STUB_OAUTH on production deploys.
CLAM_ALLOW_STUB_OAUTH=1

# Cloudflare Turnstile secret key. Default `dev-stub` short-circuits
# siteverify with a literal-string check (turnstileToken === "fail"
# rejects, anything else passes). Production: real secret via
# `wrangler secret put TURNSTILE_SECRET_KEY`.
TURNSTILE_SECRET_KEY=dev-stub

# Live-render mode in local dev — bypass KV cache so chrome edits
# (Header, Layout, styles, i18n) show on every route immediately.
# Don't set in production.
CLAM_LOCAL_DEV=1
