{
  "name": "@aotter/mantle-cloudflare",
  "version": "0.0.11-alpha.14",
  "description": "Cloudflare Workers adapter for mantle. Hono-based mountServerEndpoints / createMcpApiHandler / mountAuthorize / mountPublicRoutes. Better Auth for staff sign-in; @cloudflare/workers-oauth-provider for the MCP OAuth AS surface.",
  "license": "Apache-2.0",
  "homepage": "https://mantle.tools/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle.git",
    "directory": "packages/adapters/cloudflare"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aotter/mantle-admin-ui": "workspace:*",
    "@aotter/mantle-runtime": "workspace:*",
    "@aotter/mantle-spec": "workspace:*"
  },
  "peerDependencies": {
    "@cloudflare/workers-oauth-provider": "catalog:peer",
    "aws4fetch": "catalog:peer",
    "better-auth": "catalog:peer",
    "hono": "catalog:peer",
    "zod": "catalog:peer"
  },
  "devDependencies": {
    "@cloudflare/workers-oauth-provider": "catalog:",
    "@cloudflare/workers-types": "^4.20260520.1",
    "@types/node": "catalog:",
    "aws4fetch": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.93.0",
    "zod": "catalog:"
  }
}
