{
  "name": "@aotterclam/clam-cms-cloudflare",
  "version": "0.0.8-beta.1",
  "description": "Cloudflare Workers adapter for clam-cms. Hono-based mountServerEndpoints / mountMcp / mountPublicRoutes. Better Auth (admin + mcp plugins) for sign-in + bearer-token validation.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/clam-cms/tree/main/packages/adapters/cloudflare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/clam-cms.git",
    "directory": "packages/adapters/cloudflare"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aotterclam/clam-cms-admin-ui": "workspace:*",
    "@aotterclam/clam-cms-runtime": "workspace:*",
    "@aotterclam/clam-cms-spec": "workspace:*",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.9",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.1",
    "@types/node": "^22",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.0.0"
  }
}
