{
  "name": "@aotter/mantle-cloudflare",
  "version": "0.0.7-alpha",
  "description": "Cloudflare Workers adapter for mantle. Hono-based mountServerEndpoints / mountMcp / mountPublicRoutes. Better Auth (admin + mcp plugins) for sign-in + bearer-token validation.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/aotter/mantle/tree/main/packages/adapters/cloudflare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle.git",
    "directory": "packages/adapters/cloudflare"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aotter/mantle-admin-ui": "workspace:*",
    "@aotter/mantle-runtime": "workspace:*",
    "@aotter/mantle-spec": "workspace:*",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.9",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "wrangler": "^3.103.2"
  }
}
