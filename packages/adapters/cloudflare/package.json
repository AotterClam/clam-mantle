{
  "name": "@aotterclam/mantle-cloudflare",
  "version": "0.0.11-alpha.3",
  "description": "Cloudflare Workers adapter for mantle. Hono-based mountServerEndpoints / createMcpApiHandler / mountAuthorize / mountPublicRoutes. Better Auth for staff sign-in; @cloudflare/workers-oauth-provider for the MCP OAuth AS surface.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/mantle/tree/main/packages/adapters/cloudflare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/mantle.git",
    "directory": "packages/adapters/cloudflare"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aotterclam/mantle-admin-ui": "workspace:*",
    "@aotterclam/mantle-runtime": "workspace:*",
    "@aotterclam/mantle-spec": "workspace:*",
    "@cloudflare/workers-oauth-provider": "^0.6.0",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.11",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.1",
    "@types/node": "^22",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.91.0"
  }
}
