{
  "name": "@aotterclam/clam-cms-cloudflare",
  "version": "0.0.0",
  "description": "Cloudflare Workers adapter for clam-cms. Hono-based mountServerEndpoints / mountMcp / mountPublicRoutes. Implements the 5 runtime ports against D1 / KV / ASSETS / bearer-token OAuth verification.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/clam-cms/tree/main/packages/clam-cms-cloudflare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/clam-cms.git",
    "directory": "packages/clam-cms-cloudflare"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aotterclam/clam-cms-spec": "workspace:*",
    "@aotterclam/clam-cms-runtime": "workspace:*",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "wrangler": "^3.103.2"
  }
}
