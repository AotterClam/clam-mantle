{
  "name": "@aotter/mantle",
  "version": "0.0.11-alpha.14",
  "description": "Umbrella entry for @aotter/mantle. Adopters install this one package and import from subpaths: /spec, /runtime, /cloudflare, /admin-ui. Sub-packages remain individually installable on npm for tooling / alt-adapter authors. The Netlify adapter ships as a private workspace stub in v0.1 — its subpath will be added when the impl lands in v0.2.",
  "license": "Apache-2.0",
  "homepage": "https://mantle.tools/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle.git",
    "directory": "packages/mantle"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/spec.js",
  "types": "./dist/spec.d.ts",
  "publishConfig": {
    "access": "public",
    "tag": "alpha",
    "registry": "https://registry.npmjs.org"
  },
  "exports": {
    ".": {
      "types": "./dist/spec.d.ts",
      "import": "./dist/spec.js"
    },
    "./spec": {
      "types": "./dist/spec.d.ts",
      "import": "./dist/spec.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js"
    },
    "./admin-ui": {
      "types": "./dist/admin-ui.d.ts",
      "import": "./dist/admin-ui.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@aotter/mantle-admin-ui": "workspace:*",
    "@aotter/mantle-cloudflare": "workspace:*",
    "@aotter/mantle-runtime": "workspace:*",
    "@aotter/mantle-spec": "workspace:*"
  },
  "peerDependencies": {
    "@cloudflare/workers-oauth-provider": "catalog:peer",
    "aws4fetch": "catalog:peer",
    "better-auth": "catalog:peer",
    "hono": "catalog:peer",
    "zod": "catalog:peer"
  },
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@cloudflare/workers-oauth-provider": "catalog:",
    "@types/node": "catalog:",
    "aws4fetch": "catalog:",
    "better-auth": "catalog:",
    "hono": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=22"
  }
}
