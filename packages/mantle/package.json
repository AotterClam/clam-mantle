{
  "name": "@aotterclam/mantle",
  "version": "0.0.11-alpha.7",
  "description": "Umbrella entry for @aotterclam/mantle. Adopters install this one package and import from subpaths: /spec, /runtime, /cloudflare, /admin-ui. Sub-packages remain individually installable on npm for tooling / alt-adapter authors. The Netlify adapter ships as a private workspace stub in v0.1 — its subpath will be added when the impl lands in v0.2.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/mantle/tree/develop/packages/mantle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/mantle.git",
    "directory": "packages/mantle"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/spec.js",
  "types": "./dist/spec.d.ts",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "exports": {
    ".": {
      "types": "./dist/spec.d.ts",
      "import": "./dist/spec.js"
    },
    "./spec": {
      "types": "./dist/spec.d.ts",
      "import": "./dist/spec.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js"
    },
    "./admin-ui": {
      "types": "./dist/admin-ui.d.ts",
      "import": "./dist/admin-ui.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@aotterclam/mantle-admin-ui": "workspace:*",
    "@aotterclam/mantle-cloudflare": "workspace:*",
    "@aotterclam/mantle-runtime": "workspace:*",
    "@aotterclam/mantle-spec": "workspace:*"
  },
  "peerDependencies": {
    "@cloudflare/workers-oauth-provider": "^0.6.0",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.0",
    "hono": "^4.12.0",
    "zod": "^4.0.0"
  },
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json"
  },
  "devDependencies": {
    "@cloudflare/workers-oauth-provider": "^0.6.0",
    "@types/node": "^25",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.6.11",
    "hono": "^4.12.19",
    "typescript": "^6.0.3",
    "zod": "^4.4.2"
  },
  "engines": {
    "node": ">=22"
  }
}
