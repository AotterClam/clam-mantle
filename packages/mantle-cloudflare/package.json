{
  "name": "@aotter/mantle-cloudflare",
  "version": "0.0.6-alpha",
  "description": "Cloudflare Workers adapter for mantle. Hono-based mountServerEndpoints / mountMcp / mountPublicRoutes. Implements the 5 runtime ports against D1 / KV / ASSETS / bearer-token OAuth verification.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/aotter/mantle/tree/main/packages/mantle-cloudflare",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aotter/mantle.git",
    "directory": "packages/mantle-cloudflare"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cf": {
      "types": "./dist/cf.d.ts",
      "import": "./dist/cf.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "prebuild": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.lib.json",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@aotter/mantle-admin-ui": "workspace:*",
    "@aotter/mantle-spec": "workspace:*",
    "@aotter/mantle-runtime": "workspace:*",
    "@cloudflare/workers-oauth-provider": "^0.4.0",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251101.0",
    "@types/node": "^20",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5",
    "wrangler": "^3.103.2"
  }
}
