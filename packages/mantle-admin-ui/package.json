{
  "name": "@aotterclam/mantle-admin-ui",
  "version": "0.0.11-alpha.7",
  "description": "Admin SPA for mantle — React 19 + Vite + Tailwind v4 + shadcn. Platform-agnostic: ships a single self-contained HTML string consumed by mantle-cloudflare / mantle-netlify mount layers.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/mantle/tree/develop/packages/mantle-admin-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/mantle.git",
    "directory": "packages/mantle-admin-ui"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "main": "./dist/index-html.js",
  "types": "./dist/index-html.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index-html.d.ts",
      "import": "./dist/index-html.js"
    },
    "./index.html": "./dist/index.html"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo '(no admin-ui unit tests yet)'"
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
