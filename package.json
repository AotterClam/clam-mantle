{
  "name": "clam-cms-monorepo",
  "private": true,
  "version": "0.0.8-beta.1",
  "description": "MCP-native headless CMS for Cloudflare Workers.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/AotterClam/clam-cms",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AotterClam/clam-cms.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --filter '@aotterclam/clam-cms-*' build",
    "typecheck": "pnpm -r --filter '@aotterclam/clam-cms-*' typecheck",
    "test": "pnpm -r --filter '@aotterclam/clam-cms-*' test",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check": "pnpm run check:boundaries && pnpm build && pnpm install --frozen-lockfile && pnpm typecheck && pnpm test"
  },
  "packageManager": "pnpm@9.15.0"
}
